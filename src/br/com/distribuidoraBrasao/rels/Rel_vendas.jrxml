<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rel_vendas" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a1b2c3d4-1111-2222-3333-444455556666">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<queryString language="SQL">
		<![CDATA[SELECT v.id_vend, v.dat_vend, c.nome_cli, v.val_total_vend, v.val_custo_vend,
       (v.val_total_vend - v.val_custo_vend) AS lucro_vend,
       i.qtd_item, i.val_unit_item, p.nome_prod
FROM venda v, cliente c, item_venda i, produto p
WHERE v.id_cli = c.id_cli
AND i.id_vend = v.id_vend
AND i.id_prod = p.id_prod
ORDER BY v.dat_vend DESC, v.id_vend]]>
	</queryString>
	<field name="id_vend" class="java.lang.Integer"/>
	<field name="dat_vend" class="java.sql.Date"/>
	<field name="nome_cli" class="java.lang.String"/>
	<field name="val_total_vend" class="java.lang.Double"/>
	<field name="val_custo_vend" class="java.lang.Double"/>
	<field name="lucro_vend" class="java.lang.Double"/>
	<field name="qtd_item" class="java.lang.Integer"/>
	<field name="val_unit_item" class="java.lang.Double"/>
	<field name="nome_prod" class="java.lang.String"/>
	<variable name="totalGeralVendas" class="java.lang.Double" resetType="Group" resetGroup="grupoVenda" calculation="First">
		<variableExpression><![CDATA[$F{val_total_vend}]]></variableExpression>
		<initialValueExpression><![CDATA[new Double(0)]]></initialValueExpression>
	</variable>
	<variable name="totalGeral" class="java.lang.Double" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$V{totalGeralVendas}]]></variableExpression>
		<initialValueExpression><![CDATA[new Double(0)]]></initialValueExpression>
	</variable>
