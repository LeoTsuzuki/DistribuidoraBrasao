	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<queryString language="SQL">
		<![CDATA[SELECT d.id_desp, d.descricao_desp, d.categoria_desp,
       d.dat_vencimento_desp, d.val_desp, d.status_desp,
       d.obs_desp, f.nome_for
FROM despesa d
LEFT JOIN fornecedor f ON d.id_for = f.id_for
ORDER BY d.dat_vencimento_desp ASC, d.status_desp]]>
	</queryString>
	<field name="id_desp" class="java.lang.Integer"/>
	<field name="descricao_desp" class="java.lang.String"/>
	<field name="categoria_desp" class="java.lang.String"/>
	<field name="dat_vencimento_desp" class="java.sql.Date"/>
	<field name="val_desp" class="java.lang.Double"/>
	<field name="status_desp" class="java.lang.String"/>
	<field name="obs_desp" class="java.lang.String"/>
	<field name="nome_for" class="java.lang.String"/>
	<variable name="totalDespesas" class="java.lang.Double" resetType="Report" calculation="Sum">
		<variableExpression><![CDATA[$F{val_desp}]]></variableExpression>
		<initialValueExpression><![CDATA[new Double(0)]]></initialValueExpression>
	</variable>
